{
  "name": "lighthouse",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @lighthouse/web --filter @lighthouse/api --filter @lighthouse/vega dev",
    "dev:web": "pnpm --filter @lighthouse/web dev",
    "dev:api": "pnpm --filter @lighthouse/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "cpu-features",
      "ssh2",
      "protobufjs"
    ]
  }
}
