# Copy to .env and fill in. Never commit the real .env.

# App
LIGHTHOUSE_PORT=4000
LIGHTHOUSE_HOST=0.0.0.0
LIGHTHOUSE_DATA_DIR=/data
LIGHTHOUSE_LOG_LEVEL=info

# Dev-only: skips the Tailscale-User-Login header check. Leave empty in prod.
LIGHTHOUSE_AUTH_BYPASS=

# Docker socket (read-only mount on the api container)
DOCKER_SOCK=/var/run/docker.sock

# Internal service URLs (inside the compose network)
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# Tailscale OAuth client — https://login.tailscale.com/admin/settings/oauth
TAILSCALE_CLIENT_ID=
TAILSCALE_CLIENT_SECRET=
TAILSCALE_TAILNET=

# Self-hosted Gitea / Forgejo
GITEA_URL=
GITEA_TOKEN=
GITEA_WEBHOOK_SECRET=
